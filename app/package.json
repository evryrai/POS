{
  "name": "app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "build": {
    "appId": "com.pos.kelontong",
    "productName": "POS Toko Kelontong",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".output/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "nuxt": "^4.4.2",
    "prisma": "^7.5.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bcryptjs": "^2.4.6",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "vitest": "^4.1.0"
  }
}
